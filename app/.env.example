# Paper Agent Environment Configuration
# Copy this file to .env and fill in your values

# ─── LLM Configuration ───
# Supported: openai-compatible | anthropic | codex-cli | claude-cli | copilot-cli
OPENPRISM_LLM_PROVIDER=openai-compatible
# OpenAI-compatible API endpoint
OPENPRISM_LLM_BASE_URL=https://api.openai.com/v1
# Leave empty until you have a real key. Known example placeholders are ignored.
OPENPRISM_LLM_API_KEY=
OPENPRISM_LLM_MODEL=gpt-4o

# Browser-supplied temporary Provider endpoints cannot resolve to loopback,
# private, link-local, metadata, multicast, or reserved addresses by default.
# Administrators may explicitly allow exact hosts or wildcard subdomains when
# an authenticated user must test an internal gateway. Server-configured
# OPENPRISM_LLM_BASE_URL remains an administrator-trusted endpoint.
# OPENPRISM_PROVIDER_ALLOWED_HOSTS=llm.internal.example,*.trusted.example
# Maximum time to establish the Provider request and receive response headers.
# This does not limit the total duration of a healthy streaming answer.
# OPENPRISM_PROVIDER_RESPONSE_HEADERS_TIMEOUT_MS=15000
# Abort only when an established Provider response produces no data for this long.
# OPENPRISM_PROVIDER_STREAM_IDLE_TIMEOUT_MS=120000

# Local CLI providers use the server's existing CLI installation and login.
# They never accept executable paths or argument templates from the browser.
# CLI probe/invoke/cancel stay disabled unless OPENPRISM_API_TOKEN is set.
# OPENPRISM_LLM_PROVIDER=codex-cli
# OPENPRISM_LLM_MODEL=

# ─── Server ───
PORT=8787
# Address advertised in startup/discovery output. The listener still binds
# 0.0.0.0 for LAN access; set the actual LAN hostname/IP per deployment.
# OPENPRISM_PUBLIC_HOST=127.0.0.1

# ─── Legacy prototype (disabled by default) ───
# Temporary migration-only UI. Applies to backend routes and Vite dev/preview/build.
# Prefer the supported React workspace at /projects.
# OPENPRISM_ENABLE_LEGACY_WORKBENCH=true

# ─── Data Storage ───
# Default: repository-root papers/ directory
# OPENPRISM_DATA_DIR=/path/to/your/data
# Legacy compatibility only: OPENPRISM_PROJECTS_DIR is read only when
# OPENPRISM_DATA_DIR is absent. If both differ, OPENPRISM_DATA_DIR wins and
# the backend emits a startup warning.
# OPENPRISM_PROJECTS_DIR=/legacy/path/to/your/data

# ─── Compile Toolchain ───
# By default compilation inherits PATH and LD_LIBRARY_PATH unchanged.
# Use these optional path-list variables only when TeX/Pandoc or their shared
# libraries are installed outside the service process environment.
# OPENPRISM_COMPILE_PATH=/opt/texlive/bin/x86_64-linux:/opt/pandoc/bin
# OPENPRISM_COMPILE_LD_LIBRARY_PATH=/opt/tectonic/lib
# Optional explicit Tectonic executable used by direct LaTeX and Pandoc builds.
# OPENPRISM_TECTONIC_BINARY=/opt/tectonic/bin/tectonic

# ─── Authentication ───
# Set this to enable Bearer token auth on all non-public API endpoints.
# If it is empty, every non-public API endpoint fails closed (503).
# OPENPRISM_API_TOKEN=your-secret-token

# ─── Collaboration ───
# Token signing secret (MUST change in production)
# Optional. If collaboration is enabled, set a unique random value.
# OPENPRISM_COLLAB_TOKEN_SECRET=
# Whether to require token verification (default: true)
OPENPRISM_COLLAB_REQUIRE_TOKEN=true
# Token TTL in seconds (default: 86400 = 24h)
OPENPRISM_COLLAB_TOKEN_TTL=86400

# ─── MinerU API (PDF→MD→LaTeX conversion) ───
# OPENPRISM_MINERU_API_BASE=https://mineru.net/api/v4
# OPENPRISM_MINERU_TOKEN=your-mineru-token

# ─── Draw Image API ───
# The key is server-only: never put it in browser storage or request payloads.
# OPENPRISM_DRAW_IMAGE_API_KEY=your-image-api-key
# OPENPRISM_DRAW_IMAGE_API_BASE=https://www.right.codes/draw/v1
# OPENPRISM_DRAW_IMAGE_MODEL=gpt-image-2
# Set true to reuse OPENPRISM_LLM_BASE_URL and OPENPRISM_LLM_API_KEY.
# OPENPRISM_DRAW_IMAGE_USE_LLM_CREDENTIALS=false

# ─── Draw.io Embed ───
# The default editor is the external diagrams.net embed. Set this to an
# administrator-controlled self-hosted HTTP(S) instance for restricted networks.
# OPENPRISM_DRAWIO_EMBED_URL=https://embed.diagrams.net/?embed=1&ui=atlas&spin=1&proto=json&ready=message

# ─── Tunnel (remote collaboration without public server) ───
# Options: false | ngrok | cf | localtunnel
OPENPRISM_TUNNEL=false
# Required for ngrok:
# NGROK_AUTHTOKEN=your-ngrok-token
