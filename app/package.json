{
  "name": "paper-agent",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xzktx003/paper_wrighting.git",
    "directory": "app"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace apps/backend run dev\" \"npm --workspace apps/frontend run dev\"",
    "dev:backend": "npm --workspace apps/backend run dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "build": "npm --workspace apps/frontend run build",
    "typecheck": "npm --workspace apps/frontend exec tsc -- --noEmit",
    "start": "node --env-file-if-exists=../.env --env-file-if-exists=.env apps/backend/src/index.js",
    "preview": "npm --workspace apps/frontend run preview",
    "test": "npm run test:unit",
    "test:unit": "vitest run --exclude tests/**/*.integration.test.mjs",
    "test:integration": "node scripts/run-e2e-isolated.mjs --vitest tests/api.integration.test.mjs",
    "test:e2e": "npm run build && node scripts/run-e2e-isolated.mjs",
    "test:e2e:ui": "npm run build && node scripts/run-e2e-isolated.mjs --ui",
    "test:e2e:report": "playwright show-report",
    "release:verify": "node scripts/verify-release.mjs",
    "check": "npm run typecheck && npm run build && npm run test:unit",
    "check:full": "npm run check && npm run test:integration && npm run test:e2e",
    "skills:sync": "node scripts/sync-open-source-skills.mjs",
    "tunnel": "npm run build && cross-env OPENPRISM_TUNNEL=localtunnel node apps/backend/src/index.js",
    "tunnel:cf": "npm run build && cross-env OPENPRISM_TUNNEL=cloudflared node apps/backend/src/index.js",
    "tunnel:ngrok": "npm run build && cross-env OPENPRISM_TUNNEL=ngrok node apps/backend/src/index.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "playwright": "^1.60.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "openai": "^6.43.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^6.0.227"
  }
}
