  'Generate model cards documenting architecture, training data, performance, limitations, and intended use': { zh: '生成模型卡片，记录架构、训练数据、性能、局限性和预期用途', en: 'Generate model cards documenting architecture, training data, performance, limitations, and intended use' },
  'Model evaluation: AUC-ROC, sensitivity-specificity, calibration plots, decision curve analysis': { zh: '模型评估：AUC-ROC、敏感性-特异性、校准图、决策曲线分析', en: 'Model evaluation: AUC-ROC, sensitivity-specificity, calibration plots, decision curve analysis' },
  'Scaffold medical AI model development: architecture selection, training pipeline, validation strategy': { zh: '构建医学AI模型开发：架构选择、训练流程、验证策略', en: 'Scaffold medical AI model development: architecture selection, training pipeline, validation strategy' },
  'Model validation: internal validation (bootstrapping), external validation (temporal/spatial), subgroup performance': { zh: '模型验证：内部验证(自举法)、外部验证(时间/空间)、子组性能', en: 'Model validation: internal validation (bootstrapping), external validation (temporal/spatial), subgroup performance' },
  'Orchestrate multi-agent medical research workflows: task decomposition, agent coordination, quality control': { zh: '编排多智能体医学研究工作流：任务分解、智能体协调、质量控制', en: 'Orchestrate multi-agent medical research workflows: task decomposition, agent coordination, quality control' },
  'Structured peer review of medical manuscripts: novelty assessment, methodology critique, ethical compliance': { zh: '医学手稿结构化同行评审：新颖性评估、方法论批评、伦理合规', en: 'Structured peer review of medical manuscripts: novelty assessment, methodology critique, ethical compliance' },
  'Polish academic writing: grammar correction, style improvement, academic tone adjustment': { zh: '润色学术写作：语法纠正、风格改进、学术语气调整', en: 'Polish academic writing: grammar correction, style improvement, academic tone adjustment' },
  'Present papers effectively: slide design, talking points, Q&A preparation, timing optimization': { zh: '有效展示论文：幻灯片设计、要点准备、问答准备、时间优化', en: 'Present papers effectively: slide design, talking points, Q&A preparation, timing optimization' },
  'Render PDF documents from LaTeX or Markdown with journal-specific formatting': { zh: '从LaTeX或Markdown渲染PDF文档，具有期刊特定格式', en: 'Render PDF documents from LaTeX or Markdown with journal-specific formatting' },
