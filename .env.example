# Coding Kanban — example environment file.
#
# Copy this file to `.env` at the repository root and adjust values for your
# machine. `.env` itself is git-ignored; only this template is committed so
# everyone sees which variables exist.
#
# `scripts/restart-dev.sh` automatically sources `.env` if it exists, and
# both the Fastify backend (`apps/server`) and the Vite dev server
# (`apps/web`) read these variables at startup.

# ---------- Backend (apps/server) ----------
# Address the Fastify server binds to. Use 0.0.0.0 to accept LAN clients.
HOST=0.0.0.0
# TCP port for the Fastify server (REST + WebSocket).
PORT=4000
# Per active PTY session replay buffer kept by the backend for terminal
# remount/reconnect. Increase for very long Codex outputs; higher values use
# more backend memory per active terminal.
TERMINAL_SCROLLBACK_BYTES=4194304
# Lines captured from tmux when refreshing observe-only sessions.
TERMINAL_TMUX_CAPTURE_LINES=5000
# Fallback output entries retained in the registry when no live PTY exists.
TERMINAL_REGISTRY_OUTPUT_ENTRIES=1000

# ---------- Frontend (apps/web / Vite dev server) ----------
# Address the Vite dev server binds to.
WEB_HOST=0.0.0.0
# TCP port for the Vite dev server.
WEB_PORT=3000
# Host:port the Vite proxy should use when forwarding /api, /ws and /vscode
# to the backend. Useful when backend runs on a different host (e.g. in a
# container) than the Vite dev server.
WEB_BACKEND_HOST=localhost
WEB_BACKEND_PORT=4000
# xterm.js scrollback lines kept in the browser for mounted terminals.
VITE_TERMINAL_SCROLLBACK_LINES=20000

# ---------- Frontend HTTPS ----------
# Set to 1 to enable HTTPS for the Vite dev server. When 1, both
# VITE_DEV_HTTPS_CERT and VITE_DEV_HTTPS_KEY must be set. `restart-dev.sh`
# prefers mkcert when available so embedded VS Code Web previews/webviews keep
# working; otherwise it falls back to an OpenSSL self-signed cert under
# .dev-runtime/certs.
WEB_HTTPS=1
# VITE_DEV_HTTPS_CERT=/absolute/path/to/cert.pem
# VITE_DEV_HTTPS_KEY=/absolute/path/to/key.pem

# ---------- File browser ----------
# Default directory the built-in file browser opens on first load. Leave
# blank to fall back to the repository root (auto-detected via
# pnpm-workspace.yaml).
# FILE_BROWSER_DEFAULT_LOCAL_PATH=/data01/home/you/projects

# ---------- VS Code Web integration ----------
# Shared extensions directory for the embedded code-server. Defaults to
# ~/.vscode-server/extensions if available.
# VSCODE_WEB_EXTENSIONS_DIR=~/.vscode-server/extensions
# Public host seen by browsers when proxying /vscode — leave blank to use
# the request Host header.
# VSCODE_WEB_PUBLIC_HOST=
# Address code-server binds to internally. Defaults to 0.0.0.0.
# VSCODE_WEB_BIND_HOST=0.0.0.0
# Remote code-server bind address used for SSH-backed VS Code Web sessions.
# Defaults to 127.0.0.1 because the backend reaches it through SSH local forwarding.
# VSCODE_WEB_REMOTE_BIND_HOST=127.0.0.1
# Preferred remote code-server TCP port for SSH-backed VS Code Web sessions.
# VSCODE_WEB_REMOTE_PORT=13338
