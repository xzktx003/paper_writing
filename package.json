{
  "name": "coding-kanban-agent-orchestrator",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "concurrently \"pnpm --filter server dev\" \"pnpm --filter web dev\"",
    "dev:restart": "./scripts/restart-dev.sh",
    "build": "pnpm --filter shared build && pnpm --filter server build && pnpm --filter web build",
    "check": "pnpm --filter shared build && pnpm --filter server build && pnpm --filter web build",
    "e2e": "playwright test",
    "test": "pnpm --recursive test",
    "format": "pnpm --recursive format"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "concurrently": "^9.2.1"
  }
}